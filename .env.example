# ── OpenAI ───────────────────────────────────────────────────────────────────
AI_PROVIDER=github # Set to "github" to use GitHub Models via Azure, "openai" for direct OpenAI
OPENAI_MODEL=gpt-4o-mini
GITHUB_OPENAI_KEY=github_pat.. # Set this with github PAT if using Azure OpenAI from github models
OPENAI_API_KEY= sk-proj.. # Set this variable if using OpenAI

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=crm_user
POSTGRES_PASSWORD=crm_pass
POSTGRES_DB=crm_db

# Full connection URL (auto-built by docker-compose; override for local dev)
DATABASE_URL=postgresql://crm_user:crm_pass@localhost:5432/crm_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── App Settings ──────────────────────────────────────────────────────────────
APP_ENV=development # development | production
LOG_LEVEL=INFO

# gpt-4o-mini pricing as of 2026
COST_PER_1K_PROMPT_TOKENS=0.00015
COST_PER_1K_COMPLETION_TOKENS=0.00060

# ── Embedding Model ───────────────────────────────────────────────────────────
# Local sentence-transformers model (downloaded automatically on first run)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the API
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
